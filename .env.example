# Backend (optional override when running outside Docker)
# OCR_SERVICE_URL=http://localhost:8001
# INPAINT_SERVICE_URL=http://localhost:8002
# MAX_PDF_PAGES=10

# OCR service
# USE_GPU=true

# Inpaint service
# INPAINT_MODEL_ID=runwayml/stable-diffusion-inpainting
# INPAINT_SIZE=512
# INPAINT_STEPS=50
# INPAINT_STRENGTH=1.0
# INPAINT_PROMPT=background, clean, no text

# PDF 轉 PPT 文字字體（思源黑體）
# PPT_FONT_NAME=Source Han Sans TC
# PPT_FONT_PATH=  # 字體檔路徑（Phase 2 嵌入用，可選）
# PPT_FONT_SIZE_FACTOR=0.55  # 字體大小係數，越小字體越小（0.4~0.8 可微調）
